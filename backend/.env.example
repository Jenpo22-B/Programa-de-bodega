# URI de conexión a MongoDB
# Ejemplo local:  mongodb://localhost:27017/bodega
# Ejemplo Atlas:  mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/bodega

# Secreto para firmar los tokens JWT. Usa una cadena aleatoria larga y segura.
JWT_SECRET=cambia_esto_por_un_secreto_seguro

# Puerto en que escucha el servidor (opcional, por defecto 4000)
PORT=4000
